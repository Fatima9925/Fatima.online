<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <title>Baddie Launcher Pro</title>
    <style>
        body { margin: 0; overflow: hidden; background: #222; display: flex; justify-content: center; align-items: center; height: 100vh; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        canvas { background: #ffdae9; border: 4px solid #ff1493; border-radius: 15px; box-shadow: 0 0 50px rgba(255, 20, 147, 0.4); }
        
        /* UI Overlays */
        .overlay { position: absolute; width: 360px; height: 640px; display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 10; text-align: center; }
        #startMenu { background: linear-gradient(rgba(255,182,193,0.8), rgba(255,20,147,0.4)); border-radius: 15px; }
        
        .title-text { font-size: 45px; color: #fff; font-weight: 900; text-shadow: 4px 4px 0px #ff1493, 7px 7px 0px rgba(0,0,0,0.1); margin-bottom: 30px; letter-spacing: -2px; }
        
        .btn { background: #fff; color: #ff1493; border: none; padding: 15px 50px; font-size: 22px; font-weight: bold; border-radius: 50px; cursor: pointer; box-shadow: 0 8px 0px #ff85a2; transition: 0.1s; text-transform: uppercase; }
        .btn:active { transform: translateY(4px); box-shadow: 0 4px 0px #ff85a2; }
        
        #scoreDisplay { position: absolute; top: 40px; font-size: 60px; font-weight: 900; color: #fff; text-shadow: 3px 3px 0 #ff1493, -1px -1px 0 #ff1493, 1px -1px 0 #ff1493, -1px 1px 0 #ff1493; z-index: 5; display: none; pointer-events: none; }
    </style>
</head>
<body>

    <div id="scoreDisplay">0</div>

    <div id="startMenu" class="overlay">
        <div class="title-text">BADDIE<br>LAUNCHER</div>
        <img src="https://i.ibb.co/NgGDBgcr/1775128705992-removebg-preview.png" width="120" style="margin-bottom: 40px; filter: drop-shadow(0 10px 10px rgba(0,0,0,0.2));">
        <button class="btn" onclick="initGame()">LAUNCH</button>
    </div>

    <canvas id="game"></canvas>

    <audio id="sScream" src="https://files.catbox.moe/tkzhsm.wav"></audio>
    <audio id="sHit" src="https://files.catbox.moe/tc5gl1.mp3"></audio>
    <audio id="sJump" src="https://files.catbox.moe/ikx4os.mp3"></audio>
    <audio id="sPoint" src="https://files.catbox.moe/u8ig6t.mp3"></audio>

    <script>
        const canvas = document.getElementById('game');
        const ctx = canvas.getContext('2d');
        const scoreUI = document.getElementById('scoreDisplay');
        canvas.width = 360; canvas.height = 640;

        // Assets
        const bird = new Image(); bird.src = "https://i.ibb.co/NgGDBgcr/1775128705992-removebg-preview.png";
        const coin = new Image(); coin.src = "https://i.ibb.co/23YNrJty/1775130347248-removebg-preview.png";
        const city = new Image(); city.src = "https://i.ibb.co/gF3njnyn/1775128983181.png";

        // Sounds
        const sounds = {
            scream: document.getElementById('sScream'),
            hit: document.getElementById('sHit'),
            jump: document.getElementById('sJump'),
            point: document.getElementById('sPoint')
        };

        // Game State
        let state = {
            bird: { x: 80, y: 300, w: 65, h: 65, v: 0, g: 0.22, jump: -5.2 },
            pipes: [],
            coins: [],
            particles: [],
            score: 0,
            bgX: 0,
            active: false,
            frame: 0
        };

        function initGame() {
            Object.values(sounds).forEach(s => { s.play(); s.pause(); }); // Unlock audio
            document.getElementById('startMenu').style.display = 'none';
            scoreUI.style.display = 'block';
            reset();
            state.active = true;
            loop();
        }

        function reset() {
            state.bird.y = 300; state.bird.v = 0; state.score = 0;
            state.pipes = []; state.coins = []; state.particles = [];
            scoreUI.innerText = "0";
        }

        function spawnPipe() {
            let gap = 200;
            let h = Math.random() * (canvas.height - 350) + 100;
            state.pipes.push({ x: canvas.width, y: h, w: 75, gap: gap, passed: false });
            if(Math.random() > 0.4) {
                state.coins.push({ x: canvas.width + 120, y: h + gap/2, w: 40, collected: false });
            }
        }

        function createParticles(x, y, color) {
            for(let i=0; i<8; i++) {
                state.particles.push({
                    x, y, 
                    vx: (Math.random()-0.5)*10, 
                    vy: (Math.random()-0.5)*10, 
                    life: 1.0, 
                    color
                });
            }
        }

        function loop() {
            if(!state.active) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // 1. Draw Parallax Background
            state.bgX -= 1.2;
            if(state.bgX <= -canvas.width) state.bgX = 0;
            ctx.drawImage(city, state.bgX, 0, canvas.width, canvas.height);
            ctx.drawImage(city, state.bgX + canvas.width, 0, canvas.width, canvas.height);

            // 2. Bird Physics
            state.bird.v += state.bird.g;
            state.bird.y += state.bird.v;
            
            // 3. Pipes & Logic
            if(state.frame % 100 === 0) spawnPipe();
            
            state.pipes.forEach((p, i) => {
                p.x -= 3.2;
                // Draw Stylized Pipes
                ctx.fillStyle = "#2ecc71";
                ctx.fillRect(p.x, 0, p.w, p.y);
                ctx.fillRect(p.x, p.y + p.gap, p.w, canvas.height);
                ctx.strokeStyle = "#1b5e20"; ctx.lineWidth = 4;
                ctx.strokeRect(p.x, -5, p.w, p.y + 5);
                ctx.strokeRect(p.x, p.y + p.gap, p.w, canvas.height + 5);

                // Collision
                if(state.bird.x + 20 > p.x && state.bird.x - 20 < p.x + p.w) {
                    if(state.bird.y - 20 < p.y || state.bird.y + 20 > p.y + p.gap) die();
                }
                // Score
                if(!p.passed && p.x + p.w < state.bird.x) {
                    p.passed = true; state.score++;
                    scoreUI.innerText = state.score;
                    sounds.point.currentTime = 0; sounds.point.play();
                }
            });

            // 4. Coins
            state.coins.forEach(c => {
                c.x -= 3.2;
                if(!c.collected) {
                    ctx.drawImage(coin, c.x - c.w/2, c.y - c.w/2, c.w, c.w);
                    if(Math.hypot(state.bird.x - c.x, state.bird.y - c.y) < 40) {
                        c.collected = true; state.score += 5;
                        scoreUI.innerText = state.score;
                        createParticles(c.x, c.y, "#ffd700");
                        sounds.point.currentTime = 0; sounds.point.play();
                    }
                }
            });

            // 5. Particles
            state.particles.forEach((p, i) => {
                p.x += p.vx; p.y += p.vy; p.life -= 0.02;
                ctx.fillStyle = p.color;
                ctx.globalAlpha = p.life;
                ctx.fillRect(p.x, p.y, 6, 6);
                ctx.globalAlpha = 1;
                if(p.life <= 0) state.particles.splice(i, 1);
            });

            // 6. Draw Bird
            ctx.save();
            ctx.translate(state.bird.x, state.bird.y);
            ctx.rotate(Math.min(Math.PI/4, Math.max(-Math.PI/4, state.bird.v * 0.1)));
            ctx.drawImage(bird, -state.bird.w/2, -state.bird.h/2, state.bird.w, state.bird.h);
            ctx.restore();

            if(state.bird.y > canvas.height || state.bird.y < 0) die();
            
            state.frame++;
            requestAnimationFrame(loop);
        }

        function die() {
            state.active = false;
            sounds.hit.play();
            createParticles(state.bird.x, state.bird.y, "#ff1493");
            setTimeout(() => sounds.scream.play(), 150);
            setTimeout(() => {
                document.getElementById('startMenu').style.display = 'flex';
                scoreUI.style.display = 'none';
            }, 1500);
        }

        function jump() {
            if(!state.active) return;
            state.bird.v = state.bird.jump;
            sounds.jump.currentTime = 0;
            sounds.jump.play();
        }

        window.addEventListener('keydown', e => { if(e.code === 'Space') jump(); });
        canvas.addEventListener('touchstart', e => { jump(); e.preventDefault(); }, {passive: false});
    </script>
</body>
</html>

